<?xml version="1.0" encoding="utf-8"?>
<!-- 液态玻璃交易卡片 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外层微光 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#10FFFFFF" />
            <corners android:radius="20dp" />
            <stroke android:width="0.5dp" android:color="#30FFFFFF" />
        </shape>
    </item>
    <!-- 玻璃主体 -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#22FFFFFF"
                android:centerColor="#18FFFFFF"
                android:endColor="#10FFFFFF" />
            <corners android:radius="19dp" />
            <stroke android:width="0.5dp" android:color="#25FFFFFF" />
        </shape>
    </item>
</layer-list>
