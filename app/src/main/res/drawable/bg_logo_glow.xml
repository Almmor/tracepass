<?xml version="1.0" encoding="utf-8"?>
<!-- Logo 发光底座 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 呼吸灯外发光 -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#1500d4ff" />
        </shape>
    </item>
    <!-- 玻璃底座 -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#30FFFFFF"
                android:endColor="#15FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#50FFFFFF" />
        </shape>
    </item>
</layer-list>
