<![CDATA[
	<div>
	<t_head1><app /></t_head1> <version />
	<br /><t_splitter><br />
	<br />NFCard使用手机NFC读取非接触式IC卡中的信息。<br />
	<br />支持ISO7816-4、Felica智能卡，用来读取电子钱包（主要是公交卡）、电子现金（如闪付卡）账户中没有设置读取限制的有效期、脱机余额、交易记录。<br />
	<br />已经确认可以读出的卡片有：深圳通（新版）、上海公交卡、香港八达通、北京市政一卡通（新版）、长安通、武汉城市一卡通、银联闪付卡、交通联合卡（含电子现金）、城市一卡通互联互通卡。<br />
	<br />本程序免费、开源。允许自由传播和修改，具体的规则请遵照自由软件基金会的通用公共授权第三版（GNU GPLv3），参见 <a href="http://www.gnu.org/licenses/gpl.txt">www.gnu.org/licenses/gpl.txt</a>。<br />
	<br />最新版的程序和源代码可以从<a href="https://github.com/sinpolib/nfcard/">github.com/sinpolib/nfcard</a>获取。<br />
	<br />作者：<a href="mailto:sinpowei@gmail.com">Sinpo Lib</a>, 2015.
	</div>
	]]>
    </string></file><file path="C:\Users\almmo\Desktop\nfc\nfcard\app\src\main\res\values-zh-rTW\strings.xml" qualifiers="zh-rTW"><string name="app_name">NFCard</string><string name="font_oem1">fonts/oem1.ttf</string><string name="font_oem2">fonts/oem2.ttf</string><string name="font_oem3">fonts/oem3hk.ttf</string><string name="spec_prop_id">應用</string><string name="spec_prop_serial">號碼：\u0020</string><string name="spec_prop_param">參數：\u0020</string><string name="spec_prop_version">版本：\u0020</string><string name="spec_prop_date">生效：\u0020</string><string name="spec_prop_currency">幣種：\u0020</string><string name="spec_prop_count">交易：\u0020</string><string name="spec_prop_balance">餘額：\u0020</string><string name="spec_prop_ecash">電子現金：\u0020</string><string name="spec_prop_tlimit">單筆上限：\u0020</string><string name="spec_prop_dlimit">圈存上限：\u0020</string><string name="spec_prop_olimit">透支上限：\u0020</string><string name="spec_prop_translog">交易紀錄：</string><string name="spec_prop_access">訪問受限</string><string name="spec_prop_exception">錯誤：</string><string name="spec_cur_unknown"/><string name="spec_cur_usd">美元</string><string name="spec_cur_cny">人民幣</string><string name="spec_cur_hkd">港幣</string><string name="spec_app_unknown">未知卡</string><string name="spec_app_shenzhentong">深圳通</string><string name="spec_app_quickpass">銀聯閃付卡</string><string name="spec_app_octopus_hk">香港八達通卡</string><string name="spec_app_changantong">長安通</string><string name="spec_app_wuhantong">武漢城市一卡通</string><string name="spec_app_beijing">北京市政交通卡</string><string name="spec_app_shanghai">上海公交卡</string><string name="spec_app_debit">儲蓄卡（閃付）</string><string name="spec_app_credit">信用卡（閃付）</string><string name="spec_app_qcredit">准貸記卡（閃付）</string><string name="spec_app_tunion_ep">交通聯合卡（基礎賬戶）</string><string name="spec_app_tunion_ec">交通聯合卡（擴展賬戶）</string><string name="spec_app_cityunion">城市一卡通（%1$s）</string><string name="spec_zip_unknown">未知城市</string><string name="info_nfc_notsupport">
